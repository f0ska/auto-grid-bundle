{% block autogrid_field_ascii_content %}
    {% if (value is null or value is same as '') %}
        -
    {% elseif (action is same as 'grid') %}
        {{ value|convert_encoding('ASCII', 'UTF-8')|ag_truncate(field.view.grid_truncate) }}
    {% else %}
        {{ value|convert_encoding('ASCII', 'UTF-8') }}
    {% endif %}
{% endblock %}
