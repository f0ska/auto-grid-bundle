{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% if (ag_run(agIsAnyAllowed)) or attributes.has_custom_action is defined %}
    {% set btnClass = attributes.html_class.thead_btn|default('btn-outline-secondary') %}
    {% set btnClassActive = attributes.html_class.thead_btn_active|default('btn-primary') %}
    <th class="{{ attributes.html_class.action_column_header|default('text-end text-nowrap align-middle') }}">
        <span class="d-inline-flex align-items-center gap-1">
            {% block autogrid_grid_header_action_clear_filter %}
                {% if request.filter is defined and ag_run(agIsAllowed, 'filter') %}
                    <a class="btn btn-sm btn-outline-danger" href="{{ ag_run(agActionUrl, 'grid', {'filter': null}) }}" title="{{ 'f0ska.autogrid.button.filter_reset'|trans }}" aria-label="{{ 'f0ska.autogrid.button.filter_reset'|trans }}">
                        {{ ag_icons.filter_reset() }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_advanced_filter %}
                {% if view.advancedFilterFormView and ag_run(agIsAllowed, 'advanced_filter') %}
                    <button class="btn btn-sm {{ request.filter is defined ? btnClassActive : btnClass }}"
                            data-bs-toggle="modal"
                            data-bs-target="#adv{{ agId }}"
                            data-bs-backdrop="false"
                            title="{{ 'f0ska.autogrid.button.search'|trans }}"
                            aria-label="{{ 'f0ska.autogrid.button.search'|trans }}"
                    >{{ ag_icons.search() }}</button>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_export %}
                {% if view.exportActionFormView and view.pagination.count %}
                    <button class="btn btn-sm {{ btnClass }} dropdown-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            id="exp{{ agId }}"
                            title="{{ 'f0ska.autogrid.button.export'|trans }}"
                            aria-label="{{ 'f0ska.autogrid.button.export'|trans }}"
                    ></button>
                    <ul class="dropdown-menu">
                        {% for label,code in view.exportActionChoices %}
                            <li>
                                <button
                                    class="dropdown-item"
                                    type="submit"
                                    form="{{ view.exportActionFormView.vars.attr.id }}"
                                    name="{{ field_name(view.exportActionFormView.code) }}"
                                    value="{{ code }}"
                                >{{ label|trans }}</button>
                            </li>
                        {% endfor %}
                    </ul>
                    {{ form(view.exportActionFormView) }}
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_create %}
                {% if attributes.chrome.grid_create and ag_run(agIsAllowed, 'create') %}
                    <a class="btn btn-sm {{ btnClass }}" href="{{ ag_run(agActionUrl, 'create') }}" title="{{ 'f0ska.autogrid.button.create'|trans }}" aria-label="{{ 'f0ska.autogrid.button.create'|trans }}">
                        {{ ag_icons.add() }}
                    </a>
                {% endif %}
            {% endblock %}
        </span>

        {% block autogrid_grid_header_custom_action %}{% endblock %}
    </th>
{% endif %}
