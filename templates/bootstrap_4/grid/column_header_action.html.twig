{% if (ag_run(agIsAnyAllowed)) or attributes.has_custom_action is defined %}
    {% set btnClass = attributes.html_class.thead_btn|default('btn-outline-secondary') %}
    {% set btnClassActive = attributes.html_class.thead_btn_active|default('btn-primary') %}
    <th class="{{ attributes.html_class.action_column_header|default('text-right text-nowrap align-middle') }}">
        <span class="btn-group">
            {% block autogrid_grid_header_action_clear_filter %}
                {% if request.filter is defined and ag_run(agIsAllowed, 'filter') %}
                    <a class="btn btn-sm btn-outline-danger" href="{{ ag_run(agActionUrl, 'grid', {'filter': null}) }}">
                        {{ ag_icon('filter-reset')|raw }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_advanced_filter %}
                {% if view.advancedFilterFormView and ag_run(agIsAllowed, 'advanced_filter') %}
                    <button class="btn btn-sm {{ request.filter is defined ? btnClassActive : btnClass }}"
                            data-toggle="modal"
                            data-target="#adv{{ agId }}"
                    >{{ ag_icon('search')|raw }}</button>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_export %}
                {% if view.exportActionFormView and view.pagination.count %}
                    <button class="btn btn-sm {{ btnClass }} dropdown-toggle"
                            data-toggle="dropdown"
                            aria-expanded="false"
                            id="exp{{ agId }}"
                    ></button>
                    <ul class="dropdown-menu">
                        {% for label,code in view.exportActionChoices %}
                            <li>
                                <button
                                    class="dropdown-item"
                                    type="submit"
                                    form="{{ view.exportActionFormView.vars.attr.id }}"
                                    name="{{ field_name(view.exportActionFormView.code) }}"
                                    value="{{ code }}"
                                >{{ label|trans }}</button>
                            </li>
                        {% endfor %}
                    </ul>
                    {{ form(view.exportActionFormView) }}
                {% endif %}
            {% endblock %}
        </span>

        {% block autogrid_grid_header_action_create %}
            {% if (ag_run(agIsAllowed, 'create')) %}
                <a class="btn btn-sm {{ btnClass }}" href="{{ ag_run(agActionUrl, 'create') }}">
                    {{ ag_icon('add')|raw }}
                </a>
            {% endif %}
        {% endblock %}

        {% block autogrid_grid_header_custom_action %}{% endblock %}
    </th>
{% endif %}
