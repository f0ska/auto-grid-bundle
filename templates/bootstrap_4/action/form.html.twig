{% extends attributes.template.base|default(ag_template('base')) %}
{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% block autogrid %}
    <table class="table">
        {% block autogrid_form_header %}
            {% if attributes.chrome.form_header %}
            {% set btnClass = attributes.html_class.thead_btn|default('btn-outline-secondary') %}
            <thead class="{{ attributes.html_class.thead|default('') }}">
            <tr>
                <td class="align-middle pl-0 pr-0">
                    <div class="container-fluid py-2">
                        <div class="d-flex flex-wrap align-items-center justify-content-between">
                            <div class="d-flex flex-wrap align-items-center mb-2 mb-md-0">
                                {% block autogrid_form_header_back_button %}
                                    {% if ag_run(agIsAllowed, 'grid') %}
                                        <a class="btn btn-sm {{ btnClass }} mr-2" href="{{ ag_run(agActionUrl, 'grid') }}">
                                            {{ ag_icons.arrow_left() }}&nbsp;{{ 'f0ska.autogrid.button.back'|trans }}
                                        </a>
                                    {% endif %}
                                {% endblock %}
                                {% block autogrid_form_header_view_button %}
                                    {% if action is not same as 'create' and ag_run(agIsAllowed, 'view') and attributes.button.view.display_in_edit %}
                                        <a class="btn btn-sm {{ btnClass }} mr-2"
                                           href="{{ ag_run(agActionUrl, 'view', {'id': entity.id}) }}"
                                        >
                                            {{ ag_icons.view() }}&nbsp;{{ 'f0ska.autogrid.button.view'|trans }}
                                        </a>
                                    {% endif %}
                                {% endblock %}
                            </div>
                            <div class="flex-grow-1 text-center mb-2 mb-md-0">
                                {% block autogrid_form_header_title %}
                                    <span class="badge badge-pill badge-light text-dark font-weight-normal px-3 py-2 border">
                                        {{ ('f0ska.autogrid.action.' ~ action)|trans }}
                                        {% if action is not same as 'create' %}
                                            &nbsp;{{ ag_icons.id() }}{{ entity.id }}
                                        {% endif %}
                                    </span>
                                {% endblock %}
                            </div>
                            <div class="d-flex flex-wrap align-items-center justify-content-end">
                                {% block autogrid_form_header_submit_button %}
                                    <button class="btn btn-sm btn-outline-secondary mr-2" type="submit"
                                            form="{{ form.vars.attr.id }}">
                                        {{ ag_icons.save() }}&nbsp;{{ 'f0ska.autogrid.button.submit'|trans }}
                                    </button>
                                {% endblock %}
                                {% block autogrid_form_header_delete_button %}
                                    {% if action is not same as 'create' and ag_run(agIsAllowed, 'delete') and attributes.button.delete.display_in_edit %}
                                        <a class="btn btn-sm btn-outline-danger"
                                           href="{{ ag_run(agActionUrl, 'delete', {'id': entity.id}) }}"
                                           onclick="return confirm('{{ 'f0ska.autogrid.dialog.delete_confirm'|trans }}');"
                                        >
                                            {{ ag_icons.delete() }}&nbsp;{{ 'f0ska.autogrid.button.delete'|trans }}
                                        </a>
                                    {% endif %}
                                {% endblock %}
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
            </thead>
            {% endif %}
        {% endblock %}

        {% block autogrid_form_body %}
            <tbody class="{{ attributes.html_class.tbody|default('border-top') }}">
            <tr>
                <td class="pl-0 pr-0">
                    {% block autogrid_form_form %}
                        {% if view.formThemes is not empty %}
                            {% form_theme form with view.formThemes %}
                        {% endif %}
                        {% if view.fieldset.defined %}
                            {{ include(attributes.template.fieldset.form|default(ag_template('fieldset.form'))) }}
                        {% else %}
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col">
                                        {{ form(form) }}
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endblock %}
                </td>
            </tr>
            </tbody>
        {% endblock %}

        {% block autogrid_form_footer %}
            {% if attributes.chrome.scroll_top %}
            <tfoot class="{{ attributes.html_class.tfoot|default('border-top') }}">
            <tr>
                <td class="pl-0 pr-0">
                    <div class="container-fluid py-2">
                        <div class="d-flex justify-content-end">
                            <div>
                                <a class="btn btn-sm {{ attributes.html_class.tfoot_btn|default('btn-outline-secondary') }}"
                                   href="#{{ attributes.container_id }}"
                                >{{ ag_icons.arrow_up() }}</a>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
            </tfoot>
            {% endif %}
        {% endblock %}
    </table>
{% endblock %}
