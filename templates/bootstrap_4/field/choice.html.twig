{% block autogrid_field_choice_content %}
    {% set labels = labels %}
    {% if (labels is empty) %}
        -
    {% elseif (action is same as 'grid') %}
        {{ labels|join(', ')|ag_truncate(field.view.grid_truncate) }}
    {% elseif labels|length > 1 %}
        <ul class="list-group list-group-flush">
            {% for item in labels %}
                <li class="list-group-item">{{ item }}</li>
            {% endfor %}
        </ul>
    {% else %}
        {{ labels|first }}
    {% endif %}
{% endblock %}
