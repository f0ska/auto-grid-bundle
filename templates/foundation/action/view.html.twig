{% extends attributes.template.base|default(ag_template('base')) %}
{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% block autogrid %}
    <div class="{{ attributes.html_class.table|default('grid-container') }}">
        {% block autogrid_view_caption %}
            {% if attributes.title is not empty %}
                <div class="text-center text-secondary h4 mb-3">
                    {{ attributes.title|trans }}
                </div>
            {% endif %}
        {% endblock %}

        {% block autogrid_view_header %}
            {% set btnClass = attributes.html_class.thead_btn|default('button small') %}
            <div class="{{ attributes.html_class.thead|default('grid-x grid-padding-x grid-margin-x') }}" style="align-items: center;">
                <div class="cell small-4 text-left">
                    {% block autogrid_view_header_back_button %}
                        {% if ag_run(agIsAllowed, 'grid') %}
                            <a class="{{ btnClass }}" href="{{ ag_run(agActionUrl, 'grid') }}">
                                {{ ag_icons.arrow_left() }}&nbsp;{{ 'f0ska.autogrid.button.back'|trans }}
                            </a>
                        {% endif %}
                    {% endblock %}
                </div>
                <div class="cell small-4 text-center">
                    {% block autogrid_view_header_title %}
                        <span class="label secondary">
                            {{ ('f0ska.autogrid.action.' ~ action)|trans }}&nbsp;{{ ag_icons.id() }}{{ entity.id }}
                        </span>
                    {% endblock %}
                </div>
                <div class="cell small-4 text-right">
                    {% block autogrid_view_header_edit_button %}
                        {% if ag_run(agIsAllowed, 'edit') and attributes.button.edit.display_in_view %}
                            <a class="{{ btnClass }}" href="{{ ag_run(agActionUrl, 'edit') }}">
                                {{ ag_icons.edit() }}&nbsp;{{ 'f0ska.autogrid.button.modify'|trans }}
                            </a>
                        {% endif %}
                    {% endblock %}
                    {% block autogrid_view_header_delete_button %}
                        {% if ag_run(agIsAllowed, 'delete') and attributes.button.delete.display_in_grid %}
                            <a class="button small alert"
                               href="{{ ag_run(agActionUrl, 'delete', {'id': entity.id}) }}"
                               onclick="return confirm('{{ 'f0ska.autogrid.dialog.delete_confirm'|trans }}');"
                            >
                                {{ ag_icons.delete() }}&nbsp;{{ 'f0ska.autogrid.button.delete'|trans }}
                            </a>
                        {% endif %}
                    {% endblock %}
                </div>
            </div>
        {% endblock %}

        {% block autogrid_view_body %}
            <div class="{{ attributes.html_class.tbody|default('') }}">
                {% if view.fieldset.defined %}
                    {{ include(attributes.template.fieldset.view|default(ag_template('fieldset.view'))) }}
                {% else %}
                    <table class="hover">
                        <tbody>
                            {% for field in fields %}
                                {% if field.permissions.view %}
                                    {% block autogrid_view_body_row %}
                                        <tr>
                                            {% block autogrid_view_body_row_label %}
                                                <th class="text-right width-33 secondary">
                                                    {{ field.attributes.label|trans }}
                                                </th>
                                            {% endblock %}
                                            {% block autogrid_view_body_row_value %}
                                                <td>
                                                    {% set agView = field|ag_prepare(entity) %}{{ include(agView.template, agView.variables) }}
                                                </td>
                                            {% endblock %}
                                        </tr>
                                    {% endblock %}
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        {% endblock %}

        {% block autogrid_view_footer %}
            <div class="{{ attributes.html_class.tfoot|default('grid-x grid-padding-x') }}">
                <div class="cell text-right">
                    <a class="{{ attributes.html_class.tfoot_btn|default('button small') }}"
                       href="#{{ attributes.container_id }}"
                    >{{ ag_icons.arrow_up() }}</a>
                </div>
            </div>
        {% endblock %}
    </div>
{% endblock %}
