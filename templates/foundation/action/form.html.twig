{% extends attributes.template.base|default(ag_template('base')) %}
{% block autogrid %}
    <div class="{{ attributes.html_class.table|default('grid-container') }}">
        {% block autogrid_form_caption %}
            {% if attributes.title is not empty %}
                <div class="text-center text-secondary h4 mb-3">
                    {{ attributes.title|trans }}
                </div>
            {% endif %}
        {% endblock %}

        {% block autogrid_form_header %}
            {% set btnClass = attributes.html_class.thead_btn|default('button small') %}
            <div class="{{ attributes.html_class.thead|default('grid-x grid-padding-x grid-margin-x') }}" style="align-items: center;">
                <div class="cell small-4 text-left">
                    {% block autogrid_form_header_back_button %}
                        {% if ag_run(agIsAllowed, 'grid') %}
                            <a class="{{ btnClass }}" href="{{ ag_run(agActionUrl, 'grid') }}">
                                {{ ag_icon('arrow-left')|raw }}&nbsp;{{ 'f0ska.autogrid.button.back'|trans }}
                            </a>
                        {% endif %}
                    {% endblock %}
                    {% block autogrid_form_header_view_button %}
                        {% if action is not same as 'create' and ag_run(agIsAllowed, 'view') and attributes.button.view.display_in_edit %}
                            <a class="{{ btnClass }}"
                               href="{{ ag_run(agActionUrl, 'view', {'id': entity.id}) }}"
                            >
                                {{ ag_icon('view')|raw }}&nbsp;{{ 'f0ska.autogrid.button.view'|trans }}
                            </a>
                        {% endif %}
                    {% endblock %}
                </div>
                <div class="cell small-4 text-center">
                    {% block autogrid_form_header_title %}
                        <span class="label secondary">
                            {{ ('f0ska.autogrid.action.' ~ action)|trans }}
                            {% if action is not same as 'create' %}
                                &nbsp;{{ ag_icon('id')|raw }}{{ entity.id }}
                            {% endif %}
                        </span>
                    {% endblock %}
                </div>
                <div class="cell small-4 text-right">
                    {% block autogrid_form_header_submit_button %}
                        <button class="{{ btnClass }}" type="submit"
                                form="{{ form.vars.attr.id }}">
                            {{ ag_icon('save')|raw }}&nbsp;{{ 'f0ska.autogrid.button.submit'|trans }}
                        </button>
                    {% endblock %}
                    {% block autogrid_form_header_delete_button %}
                        {% if action is not same as 'create' and ag_run(agIsAllowed, 'delete') and attributes.button.delete.display_in_edit %}
                            <a class="button small alert"
                               href="{{ ag_run(agActionUrl, 'delete', {'id': entity.id}) }}"
                               onclick="return confirm('{{ 'f0ska.autogrid.dialog.delete_confirm'|trans }}');"
                            >
                                {{ ag_icon('delete')|raw }}&nbsp;{{ 'f0ska.autogrid.button.delete'|trans }}
                            </a>
                        {% endif %}
                    {% endblock %}
                </div>
            </div>
        {% endblock %}

        {% block autogrid_form_body %}
            <div class="{{ attributes.html_class.tbody|default('') }}">
                {% block autogrid_form_form %}
                    {% if view.formThemes is not empty %}
                        {% form_theme form with view.formThemes %}
                    {% endif %}
                    {% if view.fieldset.defined %}
                        {{ include(attributes.template.fieldset.form|default(ag_template('fieldset.form'))) }}
                    {% else %}
                        <div class="grid-container">
                            {{ form(form) }}
                        </div>
                    {% endif %}
                {% endblock %}
            </div>
        {% endblock %}

        {% block autogrid_form_footer %}
            <div class="{{ attributes.html_class.tfoot|default('grid-x grid-padding-x') }}">
                <div class="cell text-right">
                    <a class="{{ attributes.html_class.tfoot_btn|default('button small') }}"
                       href="#{{ attributes.container_id }}"
                    >{{ ag_icon('arrow-up')|raw }}</a>
                </div>
            </div>
        {% endblock %}
    </div>
{% endblock %}
