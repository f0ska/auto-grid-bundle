{% if agRun(agIsAnyAllowed) or attributes.has_custom_action is defined %}
    {% set btnClass = attributes.html_class.tbody_btn|default('button small secondary') %}
    <td class="{{ attributes.html_class.action_column|default('text-right') }}" style="white-space: nowrap;">
        <div class="button-group" style="display: inline-flex; margin-bottom: 0; gap: 0; flex-wrap: nowrap;">
            {% block autogrid_grid_row_action_view %}
                {% if agRun(agIsAllowed, 'view') and attributes.button.view.display_in_grid %}
                    <a class="{{ btnClass }}"
                       href="{{ agRun(agActionUrl, 'view', {'id': entity.id}) }}"
                    >{{ ag_icon('view')|raw }}</a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_row_action_edit %}
                {% if agRun(agIsAllowed, 'edit') and attributes.button.edit.display_in_grid %}
                    <a class="{{ btnClass }}"
                       href="{{ agRun(agActionUrl, 'edit', {'id': entity.id}) }}"
                    >{{ ag_icon('edit')|raw }}</a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_row_action_delete %}
                {% if agRun(agIsAllowed, 'delete') and attributes.button.delete.display_in_grid %}
                    <a class="button small alert"
                       href="{{ agRun(agActionUrl, 'delete', {'id': entity.id}) }}"
                       onclick="return confirm('{{ 'f0ska.autogrid.dialog.delete_confirm'|trans }}');"
                    >{{ ag_icon('delete')|raw }}</a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_row_custom_action %}{% endblock %}
        </div>
    </td>
{% endif %}
