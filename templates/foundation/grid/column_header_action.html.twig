{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% if (ag_run(agIsAnyAllowed)) or attributes.has_custom_action is defined %}
    {% set btnClass = attributes.html_class.thead_btn|default('button small secondary') %}
    {% set btnClassActive = attributes.html_class.thead_btn_active|default('button small primary') %}
    <th class="{{ attributes.html_class.action_column_header|default('text-right') }}" style="white-space: nowrap; position: relative;">
        <div style="display: inline-flex; gap: 0; float: right;">
            {% block autogrid_grid_header_action_clear_filter %}
                {% if request.filter is defined and ag_run(agIsAllowed, 'filter') %}
                    <a class="button small alert" href="{{ ag_run(agActionUrl, 'grid', {'filter': null}) }}" style="margin-bottom: 0;">
                        {{ ag_icons.filter_reset() }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_advanced_filter %}
                {% if view.advancedFilterFormView and ag_run(agIsAllowed, 'advanced_filter') %}
                    <button class="button small {{ request.filter is defined ? 'primary' : 'secondary' }}"
                            style="margin-bottom: 0;"
                            onclick="var d=document.getElementById('adv{{ agId }}');d.style.display=d.style.display=='none'?'block':'none';"
                    >{{ ag_icons.search() }}</button>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_export %}
                {% if view.exportActionFormView and view.pagination.count %}
                    <span>
                        <button class="button small secondary"
                                onclick="var d=document.getElementById('exp{{ agId }}');d.style.display=d.style.display=='none'?'block':'none'; event.stopPropagation();"
                                style="margin-bottom: 0;"
                        >{{ ag_icons.export() }}</button>
                        <div id="exp{{ agId }}" style="display: none; position: absolute; right: 0; top: 100%; z-index: 1000; background: white; border: 1px solid #ccc; padding: 10px; min-width: 300px; box-shadow: 0 2px 5px rgba(0,0,0,0.2);" onclick="event.stopPropagation();">
                            {% for label,code in view.exportActionChoices %}
                                <button
                                    class="button small expanded"
                                    type="submit"
                                    form="{{ view.exportActionFormView.vars.attr.id }}"
                                    name="{{ field_name(view.exportActionFormView.code) }}"
                                    value="{{ code }}"
                                    style="margin-bottom: 4px;"
                                >{{ label|trans }}</button>
                            {% endfor %}
                        </div>
                    </span>
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_action_export_form %}
                {% if view.exportActionFormView and view.pagination.count %}
                    {{ form(view.exportActionFormView) }}
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_action_create %}
                {% if (ag_run(agIsAllowed, 'create')) %}
                    <a class="button small success" href="{{ ag_run(agActionUrl, 'create') }}" style="margin-bottom: 0;">
                        {{ ag_icons.add() }}
                    </a>
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_custom_action %}{% endblock %}
        </div>
    </th>
{% endif %}
