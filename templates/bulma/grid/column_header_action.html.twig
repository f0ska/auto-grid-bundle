{% if (ag_run(agIsAnyAllowed)) or attributes.has_custom_action is defined %}
    {% set btnClass = attributes.html_class.thead_btn|default('is-small') %}
    {% set btnClassActive = attributes.html_class.thead_btn_active|default('is-primary') %}
    <th class="{{ attributes.html_class.action_column_header|default('has-text-right') }}" style="white-space: nowrap; position: relative;">
        <div class="buttons are-small is-right" style="justify-content: flex-end;">
            {% block autogrid_grid_header_action_clear_filter %}
                {% if request.filter is defined and ag_run(agIsAllowed, 'filter') %}
                    <a class="button is-danger" href="{{ ag_run(agActionUrl, 'grid', {'filter': null}) }}">
                        {{ ag_icon('filter-reset')|raw }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_advanced_filter %}
                {% if view.advancedFilterFormView and ag_run(agIsAllowed, 'advanced_filter') %}
                    <a class="button {{ request.filter is defined ? btnClassActive }}"
                       data-target="adv{{ agId }}"
                       onclick="document.getElementById('adv{{ agId }}').classList.add('is-active');"
                    >{{ ag_icon('search')|raw }}</a>
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_action_export %}
                {% if view.exportActionFormView and view.pagination.count %}
                    <div class="control" style="position: static;">
                        <button class="button is-info" type="button" aria-haspopup="true" onclick="var d=document.getElementById('exp{{ agId }}');d.style.display=d.style.display=='none'?'block':'none'; event.stopPropagation();">
                            {{ ag_icon('export')|raw }}
                        </button>
                        <div id="exp{{ agId }}" class="dropdown-menu" role="menu" style="position: absolute; left: auto !important; right: 0 !important; top: 100%; min-width: 200px; display: none; background: white; z-index: 1000; box-shadow: 0 2px 3px rgba(10,10,10,0.1), 0 0 0 1px rgba(10,10,10,0.1); border-radius: 4px;" onclick="event.stopPropagation();">
                            <div class="dropdown-content" style="background: white;">
                                {% for label,code in view.exportActionChoices %}
                                    <button
                                        class="dropdown-item"
                                        type="submit"
                                        form="{{ view.exportActionFormView.vars.attr.id }}"
                                        name="{{ field_name(view.exportActionFormView.code) }}"
                                        value="{{ code }}"
                                    >{{ label|trans }}</button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_action_create %}
                {% if (ag_run(agIsAllowed, 'create')) %}
                    <a class="button is-success" href="{{ ag_run(agActionUrl, 'create') }}">
                        {{ ag_icon('add')|raw }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_custom_action %}{% endblock %}
        </div>

        {% if view.exportActionFormView is defined and view.exportActionFormView %}
            {{ form(view.exportActionFormView) }}
        {% endif %}
    </th>
{% endif %}
