{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% if (ag_run(agIsAnyAllowed)) or attributes.has_custom_action is defined %}
    {% set btnClass = attributes.html_class.thead_btn|default('is-small') %}
    {% set btnClassActive = attributes.html_class.thead_btn_active|default('is-primary') %}
    <th class="{{ attributes.html_class.action_column_header|default('has-text-right') }}" style="white-space: nowrap; position: relative;">
        <div class="is-inline-flex is-align-items-center" style="gap: 0.35rem; justify-content: flex-end; flex-wrap: nowrap;">
            {% block autogrid_grid_header_action_clear_filter %}
                {% if request.filter is defined and ag_run(agIsAllowed, 'filter') %}
                    <a class="button is-danger {{ btnClass }}" href="{{ ag_run(agActionUrl, 'grid', {'filter': null}) }}" title="{{ 'f0ska.autogrid.button.filter_reset'|trans }}" aria-label="{{ 'f0ska.autogrid.button.filter_reset'|trans }}">
                        {{ ag_icons.filter_reset() }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_action_advanced_filter %}
                {% if view.advancedFilterFormView and ag_run(agIsAllowed, 'advanced_filter') %}
                    <a class="button {{ btnClass }} {{ request.filter is defined ? btnClassActive }}"
                       data-target="adv{{ agId }}"
                       onclick="document.getElementById('adv{{ agId }}').classList.add('is-active');"
                       title="{{ 'f0ska.autogrid.button.search'|trans }}"
                       aria-label="{{ 'f0ska.autogrid.button.search'|trans }}"
                    >{{ ag_icons.search() }}</a>
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_action_export %}
                {% if view.exportActionFormView and view.pagination.count %}
                    <div class="dropdown is-right" id="expWrap{{ agId }}">
                        <div class="dropdown-trigger">
                            <button class="button is-info {{ btnClass }}" type="button" aria-haspopup="true" aria-controls="exp{{ agId }}"
                                    title="{{ 'f0ska.autogrid.button.export'|trans }}"
                                    aria-label="{{ 'f0ska.autogrid.button.export'|trans }}"
                                    onclick="var d=document.getElementById('expWrap{{ agId }}');d.classList.toggle('is-active'); event.stopPropagation();">
                                <span class="is-sr-only">{{ 'f0ska.autogrid.button.export'|trans }}</span>
                                <span>{{ ag_icons.export() }}</span>
                            </button>
                        </div>
                        <div id="exp{{ agId }}" class="dropdown-menu" role="menu">
                            <div class="dropdown-content">
                                {% for label,code in view.exportActionChoices %}
                                    <button
                                        class="dropdown-item"
                                        type="submit"
                                        form="{{ view.exportActionFormView.vars.attr.id }}"
                                        name="{{ field_name(view.exportActionFormView.code) }}"
                                        value="{{ code }}"
                                    >{{ label|trans }}</button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_header_action_create %}
                {% if attributes.chrome.grid_create and ag_run(agIsAllowed, 'create') %}
                    <a class="button is-success {{ btnClass }}" href="{{ ag_run(agActionUrl, 'create') }}" title="{{ 'f0ska.autogrid.button.create'|trans }}" aria-label="{{ 'f0ska.autogrid.button.create'|trans }}">
                        {{ ag_icons.add() }}
                    </a>
                {% endif %}
            {% endblock %}
            {% block autogrid_grid_header_custom_action %}{% endblock %}
        </div>

        {% if view.exportActionFormView is defined and view.exportActionFormView %}
            {{ form(view.exportActionFormView) }}
        {% endif %}
    </th>
{% endif %}
