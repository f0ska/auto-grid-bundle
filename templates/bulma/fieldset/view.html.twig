<div class="is-fullwidth mb-5">
    <div class="columns is-multiline">
        {% for fieldset in view.fieldset.defined %}
            {% block autogrid_fieldset_view_card %}
                <div class="column {{ fieldset.class|default('is-full') }}">
                    <div class="box">
                        {% block autogrid_fieldset_view_header %}
                            <p class="title is-5 mb-4">{{ fieldset.name|trans }}</p>
                        {% endblock %}
                        {% block autogrid_fieldset_view_body %}
                            <div>
                                {% for fieldName in fieldset.fields %}
                                    {% set field = attribute(fields, fieldName) %}
                                    <div class="{{ not loop.first ? 'pt-4 mt-4 has-border-top' : '' }}">
                                        <div class="is-size-7 has-text-weight-semibold has-text-grey is-uppercase mb-2" style="letter-spacing: .06em;">
                                            {{ field.attributes.label|trans }}
                                        </div>
                                        <div class="has-text-dark" style="line-height: 1.6;">
                                            {% set agView = field|ag_prepare(entity) %}{{ include(agView.template, agView.variables) }}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endblock %}
                    </div>
                </div>
            {% endblock %}
        {% endfor %}
        {% if view.fieldset.not_defined %}
            {% block autogrid_fieldset_view_no_fieldset %}
                <div class="column is-full">
                    <div class="box">
                        {% for fieldName in view.fieldset.not_defined %}
                            {% set field = attribute(fields, fieldName) %}
                            <div class="{{ not loop.first ? 'pt-4 mt-4 has-border-top' : '' }}">
                                <div class="is-size-7 has-text-weight-semibold has-text-grey is-uppercase mb-2" style="letter-spacing: .06em;">
                                    {{ field.attributes.label|trans }}
                                </div>
                                <div class="has-text-dark" style="line-height: 1.6;">
                                    {% set agView = field|ag_prepare(entity) %}{{ include(agView.template, agView.variables) }}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endblock %}
        {% endif %}
    </div>
</div>
