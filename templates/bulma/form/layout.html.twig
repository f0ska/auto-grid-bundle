{% use 'form_div_layout.html.twig' %}

{%- block form_row -%}
    <div class="field">
        {{- form_label(form) -}}
        <div class="control{% if form.vars.attr.class is defined %} {{ form.vars.attr.class }}{% endif %}">
            {{- form_widget(form) -}}
        </div>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock form_row -%}

{%- block form_widget_compound -%}
    <div {{ block('widget_container_attributes') }}>
        {%- if form is rootform -%}
            {{- form_errors(form) -}}
        {%- endif -%}
        {{- block('form_rows') -}}
    </div>
{%- endblock form_widget_compound -%}

{%- block checkbox_row -%}
    <div class="field">
        <div class="control">
            <label class="checkbox">
                {{- form_widget(form) -}}
                {{- form_label(form) -}}
            </label>
        </div>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock checkbox_row -%}

{%- block radio_row -%}
    <div class="field">
        <div class="control">
            <label class="radio">
                {{- form_widget(form) -}}
                {{- form_label(form) -}}
            </label>
        </div>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock radio_row -%}

{%- block switch_row -%}
    <div class="field">
        <div class="control">
            <label class="switch">
                {{- form_widget(form) -}}
                {{- form_label(form) -}}
            </label>
        </div>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock switch_row -%}

{%- block button_row -%}
    <div class="field">
        <div class="control">
            {{- form_widget(form) -}}
        </div>
    </div>
{%- endblock button_row -%}

{%- block submit_row -%}
    <div class="field">
        <div class="control">
            {{- form_widget(form) -}}
        </div>
    </div>
{%- endblock submit_row -%}

{%- block reset_row -%}
    <div class="field">
        <div class="control">
            {{- form_widget(form) -}}
        </div>
    </div>
{%- endblock reset_row -%}

{%- block form_label -%}
    {%- if label is not same as(false) -%}
        {%- if compound is defined and compound -%}
            {%- set element = 'label' -%}
        {%- else -%}
            {%- set element = 'label' -%}
        {%- endif -%}
        {%- if required -%}
            {%- set label_attr = label_attr|merge({'class': (label_attr.class|default('') ~ ' label')|trim}) -%}
        {%- endif -%}
        <{{ element|raw }} {% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}>
        {%- if translation_domain is same as(false) -%}
            {{- label -}}
        {%- else -%}
            {{- label|trans(translation_parameters, translation_domain) -}}
        {%- endif -%}
        </{{ element|raw }}>
    {%- endif -%}
{%- endblock form_label -%}

{%- block checkbox_label -%}
    {{- block('form_label') -}}
{%- endblock checkbox_label -%}

{%- block radio_label -%}
    {{- block('form_label') -}}
{%- endblock radio_label -%}

{%- block form_help -%}
    {%- if help is not empty -%}
        <p class="help{% if help_type != 'help' %} is-{{ help_type }}{% endif %}">
            {%- if translation_domain is same as(false) -%}
                {{- help -}}
            {%- else -%}
                {{- help|trans(help_translation_parameters, translation_domain) -}}
            {%- endif -%}
        </p>
    {%- endif -%}
{%- endblock form_help -%}

{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        {%- for error in errors -%}
            <p class="help is-danger">{{ error.message }}</p>
        {%- endfor -%}
    {%- endif -%}
{%- endblock form_errors -%}

{%- block form -%}
    {{- form_start(form, {attr: attr|merge({class: (attr.class|default('') ~ ' form')|trim})}) -}}
        {{- form_widget(form) -}}
    {{- form_end(form) -}}
{%- endblock form -%}

{%- block choice_widget_collapsed -%}
    {%- if required and placeholder is empty -%}
        {%- set required = false -%}
    {%- endif -%}
    <div class="select is-fullwidth{% if errors|length > 0 %} is-danger{% endif %}">
        <select {{ block('widget_attributes') }}{% if multiple %} multiple="multiple"{% endif %}>
            {%- if placeholder is not empty -%}
                <option value=""{% if value is empty and not suppress_required %} selected="selected"{% endif %}>{{ placeholder != '' ? (placeholder|trans({}, translation_domain)) }}</option>
            {%- endif -%}
            {%- if preferred_choices|length > 0 -%}
                {%- set options = preferred_choices -%}
                {{- block('choice_widget_options') -}}
                {%- if choices|length > 0 and separator is not none -%}
                    <option disabled="disabled">{{ separator }}</option>
                {%- endif -%}
            {%- endif -%}
            {%- set options = choices -%}
            {{- block('choice_widget_options') -}}
        </select>
    </div>
{%- endblock choice_widget_collapsed -%}

{%- block textarea_widget -%}
    <textarea {{ block('widget_attributes') }}class="textarea{% if errors|length > 0 %} is-danger{% endif %}" rows="4">{{ value }}</textarea>
{%- endblock textarea_widget -%}
