{% extends attributes.template.base|default(ag_template('base')) %}
{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% block autogrid %}
    {{ include(attributes.template.grid.advanced_filter|default(ag_template('grid.advanced_filter'))) }}
    {% set columnsCount = (fields|length) + (ag_run(agIsAnyAllowed) ? 1 : 0) + (view.massActionFormView ? 1 : 0) %}
    <table class="table is-fullwidth {{ attributes.html_class.table|default('is-hoverable') }}">
        {{ include(attributes.template.grid.colgroup|default(ag_template('grid.colgroup'))) }}

        {% block autogrid_grid_header %}
            <thead class="{{ attributes.html_class.thead|default('') }}">
                <tr>
                    {{ include(attributes.template.grid.column_header_massaction|default(ag_template('grid.column_header_massaction'))) }}
                    {% for field in fields %}
                        {{ include(attributes.template.grid.column_header|default(ag_template('grid.column_header'))) }}
                    {% endfor %}
                    {{ include(attributes.template.grid.column_header_action|default(ag_template('grid.column_header_action'))) }}
                </tr>
            </thead>
        {% endblock %}

        {% block autogrid_grid_body %}
            <tbody class="{{ attributes.html_class.tbody|default('') }}">
            {% if rows is empty %}
                {% block autogrid_grid_body_empty %}
                    <tr>
                        <td class="has-text-grey has-text-centered" colspan="{{ columnsCount }}">
                            {{ 'f0ska.autogrid.empty'|trans }}
                        </td>
                    </tr>
                {% endblock %}
            {% endif %}
            {% for entity in rows %}
                {% block autogrid_grid_row %}
                    <tr class="{{ include(attributes.template.grid.row_class|default(ag_template('grid.row_class'))) }}">
                        {{ include(attributes.template.grid.column_value_massaction|default(ag_template('grid.column_value_massaction'))) }}
                        {% for field in fields %}
                            {{ include(attributes.template.grid.column_value|default(ag_template('grid.column_value'))) }}
                        {% endfor %}
                        {{ include(attributes.template.grid.column_value_action|default(ag_template('grid.column_value_action'))) }}
                    </tr>
                {% endblock %}
            {% endfor %}
            </tbody>
        {% endblock %}

        {% block autogrid_grid_footer %}
            <tfoot class="{{ attributes.html_class.tfoot|default('') }}">
                <tr>
                    <td colspan="{{ columnsCount }}">
                        <nav class="level is-mobile" role="navigation">
                            <div class="level-left">
                                <div class="level-item has-text-grey">
                                    <span><strong>{{ 'f0ska.autogrid.total'|trans }}:</strong>&nbsp;{{ view.pagination.count }}</span>
                                </div>
                            </div>
                            <div class="level-item">
                                <div class="is-inline-flex is-align-items-center" style="gap: 0.25rem; flex-wrap: wrap; justify-content: center;">
                                    {{ include(attributes.template.grid.grid_pagination|default(ag_template('grid.grid_pagination'))) }}
                                </div>
                            </div>
                            <div class="level-right">
                                <div class="level-item">
                                    <div class="is-inline-flex is-align-items-center" style="gap: 0.25rem; flex-wrap: wrap; justify-content: flex-end;">
                                        {{ include(attributes.template.grid.grid_number_per_page|default(ag_template('grid.grid_number_per_page'))) }}
                                        <a class="button is-small"
                                           href="#{{ attributes.container_id }}"
                                        >{{ ag_icons.arrow_up() }}</a>
                                    </div>
                                </div>
                            </div>
                        </nav>
                    </td>
                </tr>
            </tfoot>
        {% endblock %}
    </table>
{% endblock %}
