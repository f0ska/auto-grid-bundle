{% extends attributes.template.base|default(ag_template('base')) %}
{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% block autogrid %}
    {% block autogrid_error_content %}
        <div class="notification is-danger is-light has-text-centered">
            {{ ag_icons.warning() }}
            {{ message }}
        </div>
    {% endblock %}
{% endblock %}
