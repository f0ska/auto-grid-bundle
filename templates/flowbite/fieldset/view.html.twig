<div class="px-4 py-5 sm:px-6">
    <div class="grid gap-5 xl:grid-cols-2">
        {% for fieldset in view.fieldset.defined %}
            {% block autogrid_fieldset_view_card %}
                <div class="w-full {{ fieldset.class|default('') }}">
                    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                        {% block autogrid_fieldset_view_header %}
                            <h5 class="border-b border-gray-200 bg-gray-50 px-5 py-4 text-sm font-semibold uppercase tracking-wide text-gray-600">
                                {{ fieldset.name|trans }}
                            </h5>
                        {% endblock %}
                        {% block autogrid_fieldset_view_body %}
                            <div>
                                {% for fieldName in fieldset.fields %}
                                    {% set field = attribute(fields, fieldName) %}
                                    <div class="px-5 py-4 {{ not loop.first ? 'border-t border-gray-200' : '' }}">
                                        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">
                                            {{ field.attributes.label|trans }}
                                        </div>
                                        <div class="text-sm leading-6 text-gray-900">
                                            {% set agView = field|ag_prepare(entity) %}{{ include(agView.template, agView.variables) }}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endblock %}
                    </div>
                </div>
            {% endblock %}
        {% endfor %}
        {% if view.fieldset.not_defined %}
            {% block autogrid_fieldset_view_no_fieldset %}
                <div class="xl:col-span-2">
                    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                        {% for fieldName in view.fieldset.not_defined %}
                            {% set field = attribute(fields, fieldName) %}
                            <div class="px-5 py-4 {{ not loop.first ? 'border-t border-gray-200' : '' }}">
                                <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">
                                    {{ field.attributes.label|trans }}
                                </div>
                                <div class="text-sm leading-6 text-gray-900">
                                    {% set agView = field|ag_prepare(entity) %}{{ include(agView.template, agView.variables) }}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endblock %}
        {% endif %}
    </div>
</div>
