{% extends attributes.template.base|default(ag_template('base')) %}
{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% block autogrid %}
    {% block autogrid_error_content %}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative text-center h4 mb-0" role="alert">
            {{ ag_icons.warning() }}
            {{ message }}
        </div>
    {% endblock %}
{% endblock %}
