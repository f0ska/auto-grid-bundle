{% extends attributes.template.base|default(ag_template('base')) %}
{% import attributes.template.icons|default(ag_template('icons')) as ag_icons %}
{% block autogrid %}
    <div class="{{ attributes.html_class.table|default('w-full overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm') }}">
        {% block autogrid_view_caption %}
            {% if attributes.title is not empty %}
                <div class="mb-4 text-center text-xl font-semibold text-gray-900">
                    {{ attributes.title|trans }}
                </div>
            {% endif %}
        {% endblock %}

        {% block autogrid_view_header %}
            {% set btnClass = 'inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium leading-5 text-gray-700 shadow-xs transition hover:bg-gray-100 hover:text-gray-900 focus:outline-none' %}
            {% set btnDelClass = 'inline-flex items-center gap-2 rounded-lg bg-red-700 px-3 py-2 text-sm font-medium leading-5 text-white shadow-xs transition hover:bg-red-800 focus:outline-none' %}
            <div class="{{ attributes.html_class.thead|default('flex flex-wrap items-center gap-3 border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6') }}">
                <div class="flex flex-1 flex-wrap items-center gap-2">
                    {% block autogrid_view_header_back_button %}
                        {% if ag_run(agIsAllowed, 'grid') %}
                            <a class="{{ btnClass }}" href="{{ ag_run(agActionUrl, 'grid') }}">
                                {{ ag_icons.arrow_left() }}<span>{{ 'f0ska.autogrid.button.back'|trans }}</span>
                            </a>
                        {% endif %}
                    {% endblock %}
                </div>
                <div class="order-first w-full text-center md:order-none md:w-auto">
                    {% block autogrid_view_header_title %}
                        <span class="inline-flex items-center gap-2 rounded-full bg-gray-100 px-4 py-2 text-sm font-medium text-gray-600">
                            <span>{{ ('f0ska.autogrid.action.' ~ action)|trans }}</span>
                            <span class="inline-flex items-center gap-1 whitespace-nowrap">{{ ag_icons.id() }}{{ entity.id }}</span>
                        </span>
                    {% endblock %}
                </div>
                <div class="flex flex-1 flex-wrap items-center justify-end gap-2">
                    {% block autogrid_view_header_edit_button %}
                        {% if ag_run(agIsAllowed, 'edit') and attributes.button.edit.display_in_view %}
                            <a class="{{ btnClass }}" href="{{ ag_run(agActionUrl, 'edit') }}">
                                {{ ag_icons.edit() }}<span>{{ 'f0ska.autogrid.button.modify'|trans }}</span>
                            </a>
                        {% endif %}
                    {% endblock %}
                    {% block autogrid_view_header_delete_button %}
                        {% if ag_run(agIsAllowed, 'delete') and attributes.button.delete.display_in_grid %}
                            <a class="{{ btnDelClass }}"
                               href="{{ ag_run(agActionUrl, 'delete', {'id': entity.id}) }}"
                               onclick="return confirm('{{ 'f0ska.autogrid.dialog.delete_confirm'|trans }}');"
                            >
                                {{ ag_icons.delete() }}<span>{{ 'f0ska.autogrid.button.delete'|trans }}</span>
                            </a>
                        {% endif %}
                    {% endblock %}
                </div>
            </div>
        {% endblock %}

        {% block autogrid_view_body %}
            <div class="{{ attributes.html_class.tbody|default('bg-white') }}">
                {% if view.fieldset.defined %}
                    {{ include(attributes.template.fieldset.view|default(ag_template('fieldset.view'))) }}
                {% else %}
                    <div class="px-4 py-5 sm:px-6">
                        <div class="rounded-xl border border-gray-200 bg-white">
                            {% for field in fields %}
                                {% if field.permissions.view %}
                                    {% block autogrid_view_body_row %}
                                        <div class="px-5 py-4 {{ not loop.first ? 'border-t border-gray-200' : '' }}">
                                            {% block autogrid_view_body_row_label %}
                                                <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">
                                                    {{ field.attributes.label|trans }}
                                                </div>
                                            {% endblock %}
                                            {% block autogrid_view_body_row_value %}
                                                <div class="text-sm leading-6 text-gray-900">
                                                    {% set agView = field|ag_prepare(entity) %}{{ include(agView.template, agView.variables) }}
                                                </div>
                                            {% endblock %}
                                        </div>
                                    {% endblock %}
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        {% endblock %}

        {% block autogrid_view_footer %}
            <div class="{{ attributes.html_class.tfoot|default('flex justify-end border-t border-gray-200 bg-gray-50 px-4 py-4 sm:px-6') }}">
                <a class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium leading-5 text-gray-700 shadow-xs transition hover:bg-gray-100 hover:text-gray-900 focus:outline-none"
                   href="#{{ attributes.container_id }}"
                >{{ ag_icons.arrow_up() }}</a>
            </div>
        {% endblock %}
    </div>
{% endblock %}
