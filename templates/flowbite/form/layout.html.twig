{% extends 'tailwind_2_layout.html.twig' %}

{%- block form_row -%}
    {%- set row_attr = row_attr|merge({class: row_attr.class|default('mb-5')}) -%}
    {{- parent() -}}
{%- endblock form_row -%}

{%- block form_label -%}
    {%- set label_attr = label_attr|merge({class: label_attr.class|default('ms-2 text-sm font-medium text-heading')}) -%}
    {{- parent() -}}
{%- endblock form_label -%}

{%- block widget_attributes -%}
    {%- set extra_class = 'bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500' -%}
    {%- if form.vars.checked is defined -%}
        {%- set extra_class = 'w-4 h-4 border border-gray-300 rounded bg-gray-50 focus:ring-2 focus:ring-blue-300 dark:border-gray-600 dark:bg-gray-700 dark:focus:ring-blue-600' -%}
        {%- if form.vars.expanded is defined and form.vars.expanded -%}
            {%- set extra_class = extra_class ~ ' rounded-full' -%}
        {%- endif -%}
    {%- elseif type|default('') == 'file' -%}
        {%- set extra_class = 'cursor-pointer ' ~ extra_class -%}
    {%- elseif disabled -%}
        {%- set extra_class = 'bg-gray-100 border border-gray-300 text-gray-500 text-sm rounded-lg block w-full p-2.5 cursor-not-allowed dark:bg-gray-700 dark:border-gray-600 dark:text-gray-400' -%}
    {%- elseif attr.readonly|default(false) -%}
        {%- set extra_class = 'bg-gray-100 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300' -%}
    {%- elseif errors|length > 0 -%}
        {%- set extra_class = 'bg-red-50 border border-red-500 text-red-900 text-sm rounded-lg focus:ring-red-500 focus:border-red-500 block w-full p-2.5 dark:bg-red-900/20 dark:text-red-400 dark:border-red-400 border-red-700' -%}
    {%- endif -%}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' ' ~ extra_class)|trim}) -%}
    {{- parent() -}}
{%- endblock widget_attributes -%}

{%- block textarea_widget -%}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500')|trim}) -%}
    {{- parent() -}}
{%- endblock textarea_widget -%}

{%- block choice_widget_collapsed -%}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500')|trim}) -%}
    {{- parent() -}}
{%- endblock choice_widget_collapsed -%}

{%- block submit_row -%}
    <div class="mb-5">
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center focus:outline-none dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800')|trim}) -%}
        {{- form_widget(form, {attr: attr}) -}}
    </div>
{%- endblock submit_row -%}

{%- block reset_row -%}
    <div class="mb-5">
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 text-center focus:outline-none dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700')|trim}) -%}
        {{- form_widget(form, {attr: attr}) -}}
    </div>
{%- endblock reset_row -%}

{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul class="mt-1.5 text-sm text-red-600 dark:text-red-400">
            {%- for error in errors -%}
                <li>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{%- endblock form_errors -%}

{%- block form_help -%}
    {%- if help is not empty -%}
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">{{ help }}</p>
    {%- endif -%}
{%- endblock form_help -%}
