{% if field.permissions.grid %}
    {% block autogrid_grid_column_header_cell %}
        <th class="px-6 py-3 {{ field.attributes.column_html_class.header|default('text-right') }}">
            {% block autogrid_grid_column_header_sort %}
                {% if (field.canSort) %}
                    {{ include(attributes.template.grid.column_header_sort|default(agTemplate('grid.column_header_sort'))) }}
                {% endif %}
            {% endblock %}

            {% block autogrid_grid_column_header_label %}
                {{ field.attributes.label|trans }}
            {% endblock %}

            {% block autogrid_grid_column_header_filter %}
                {% if (field.canFilter and agRun(agIsAllowed, 'filter')) %}
                    {{ include(attributes.template.grid.column_header_filter|default(agTemplate('grid.column_header_filter'))) }}
                {% endif %}
            {% endblock %}
        </th>
    {% endblock %}
{% endif %}
