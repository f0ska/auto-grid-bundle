{% if field.permissions.grid %}
    {% block autogrid_grid_column_value_cell %}
        <td class="px-6 py-3 {{ field.attributes.column_html_class.value|default('') }}">
            {% block autogrid_grid_column_value_content %}
                {{ include(field.view.template) }}
            {% endblock %}
        </td>
    {% endblock %}
{% endif %}
