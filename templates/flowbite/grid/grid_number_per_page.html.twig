{% if view.pagination.limits|length > 1 %}
    {% block autogrid_grid_limit %}
        <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-500">{{ 'f0ska.autogrid.rows'|trans }}</span>
            <div class="inline-flex shadow-xs -space-x-px" role="group">
            {% set baseBtnClass = 'cursor-pointer border border-gray-200 bg-gray-50 px-2.5 py-1 text-sm font-medium leading-5 text-gray-500 transition hover:border-gray-300 hover:bg-white hover:text-gray-800 focus:outline-none' %}
            {% set activeBtnClass = 'cursor-pointer border border-gray-200 bg-gray-100 px-2.5 py-1 text-sm font-medium leading-5 text-blue-600 focus:outline-none' %}
            {% for pageLimit in view.pagination.limits %}
                {% if pageLimit == view.pagination.limit %}
                    {% block autogrid_grid_limit_active %}
                        <button type="button" class="{{ activeBtnClass }}{% if loop.first %} rounded-s-md{% endif %}{% if loop.last %} rounded-e-md{% endif %}">{{ pageLimit }}</button>
                    {% endblock %}
                {% else %}
                    {% block autogrid_grid_limit_button %}
                        {% set calcOffset = (view.pagination.count > view.pagination.limit ? view.pagination.limit : view.pagination.count) * (view.pagination.page - 1) + 1 %}
                        {% set toPage = (calcOffset / pageLimit)|round(0, 'ceil')|ag_to_int %}
                        <button type="button"
                                onclick="window.location.href='{{ ag_run(agActionUrl, 'grid', {'limit': pageLimit, 'page': toPage}) }}'"
                                class="{{ baseBtnClass }}{% if loop.first %} rounded-s-md{% endif %}{% if loop.last %} rounded-e-md{% endif %}">{{ pageLimit }}</button>
                    {% endblock %}
                {% endif %}
            {% endfor %}
            </div>
        </div>
    {% endblock %}
{% endif %}
