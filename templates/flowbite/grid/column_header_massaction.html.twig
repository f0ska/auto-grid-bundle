{% if view.massActionFormView %}
    {% block autogrid_grid_column_header_massaction %}
        <th class="px-6 py-3 {{ attributes.html_class.mass_action_column_header|default('text-center') }}">
            {{ form_start(view.massActionFormView) }}
            {% block autogrid_grid_column_header_massaction_dropdown %}
                <span style="position: relative; display: inline-block;">
                    <button type="button"
                            class="text-gray-700 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-900 font-medium leading-5 text-sm px-3 py-2 focus:outline-none rounded-base"
                            onclick="var d=document.getElementById('mass{{ agId }}');d.style.display=d.style.display=='none'?'block':'none';event.stopPropagation();"
                    >{{ ag_icon('chevron-down')|raw }}</button>
                        <div id="mass{{ agId }}" style="display: none; position: absolute; left: 0; z-index: 1000; background: white; border: 1px solid #e5e7eb; padding: 8px; min-width: 240px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); border-radius: 0.5rem;">
                        {% block autogrid_grid_column_header_massaction_choices %}
                            {% for label,code in view.massActionChoices %}
                                <button
                                    class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded"
                                    type="submit"
                                    form="{{ view.massActionFormView.vars.attr.id }}"
                                    name="{{ field_name(view.massActionFormView.code) }}"
                                    value="{{ code }}"
                                >{{ label|trans }}</button>
                            {% endfor %}
                        {% endblock %}
                        <hr class="my-2 border-gray-200">
                        {% block autogrid_grid_column_header_massaction_select_all %}
                            <label class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer rounded">
                                <input class="w-4 h-4 mr-2 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                       type="checkbox"
                                       autocomplete="off"
                                       onchange="document.querySelectorAll('[name={{ ('"' ~ field_name(view.massActionFormView.ids) ~ '[]"')|escape('html_attr') }}]').forEach(checkbox => { checkbox.checked = this.checked; })"
                                >
                                {{ 'f0ska.autogrid.action.select_all'|trans }}
                            </label>
                        {% endblock %}
                    </div>
                </span>
            {% endblock %}
            {{ form_end(view.massActionFormView) }}
        </th>
    {% endblock %}
{% endif %}
