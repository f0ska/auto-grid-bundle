{% if view.searchFormView and ag_run(agIsGranted, 'search') %}
    {% if view.formThemes is not empty %}
        {% form_theme view.searchFormView with view.formThemes %}
    {% endif %}
    <style>
        .autogrid-flowbite-search-input::placeholder {
            color: var(--color-gray-400);
        }
    </style>
    <div class="mb-4">
        {{ form_start(view.searchFormView) }}
            <div class="flex gap-2">
                {{ form_widget(view.searchFormView.term, {'attr': {'class': 'autogrid-flowbite-search-input bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5', 'placeholder': 'f0ska.autogrid.placeholder.search'|trans}}) }}
                <button class="cursor-pointer text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 rounded-lg text-sm px-5 py-2.5" type="submit">
                    {{- 'f0ska.autogrid.button.submit'|trans -}}
                </button>
                <a class="{% if request.search is not defined %}opacity-50 cursor-not-allowed {% endif %}text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-gray-200 rounded-lg text-sm px-5 py-2.5"
                   href="{{ ag_run(agActionUrl, 'grid', {'search': null, 'page': null}) }}"
                >
                    {{- 'f0ska.autogrid.button.reset'|trans -}}
                </a>
            </div>
        {{ form_end(view.searchFormView) }}
    </div>
{% endif %}
