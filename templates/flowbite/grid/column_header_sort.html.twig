{% set linkClass = attributes.html_class.thead_link|default('text-gray-500 hover:text-gray-700') %}
{% set linkClassActive = attributes.html_class.thead_link_active|default('text-blue-600 hover:text-blue-800') %}

{% block autogrid_grid_column_header_sort %}
    {% if (attribute(request.order ?? {}, field.name) is not defined) or attribute(request.order, field.name) is same as null %}
        {% block autogrid_grid_column_header_sort_none %}
            <a class="{{ linkClass }}"
               href="{{ agRun(agActionUrl, 'grid', {'order': {(field.name): 'asc'}}) }}"
            ><i class="bi bi-chevron-expand"></i></a>
        {% endblock %}
    {% elseif attribute(request.order, field.name) is same as 'asc' %}
        {% block autogrid_grid_column_header_sort_asc %}
            <a class="{{ linkClassActive }}"
               href="{{ agRun(agActionUrl, 'grid', {'order': {(field.name): 'desc'}}) }}"
            ><i class="bi bi-caret-up-fill"></i></a>
        {% endblock %}
    {% else %}
        {% block autogrid_grid_column_header_sort_desc %}
            <a class="{{ linkClassActive }}"
               href="{{ agRun(agActionUrl, 'grid', {'order': {(field.name): null}}) }}"
            ><i class="bi bi-caret-down-fill"></i></a>
        {% endblock %}
    {% endif %}
{% endblock %}
