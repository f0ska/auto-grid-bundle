{% set isFilterActive = (attribute(request.filter ?? {}, field.name) is defined) and attribute(request.filter, field.name) is not same as null %}
{% set linkClass = attributes.html_class.thead_link|default('text-gray-500 hover:text-gray-700') %}
{% set linkClassActive = attributes.html_class.thead_link_active|default('text-blue-600 hover:text-blue-800') %}
{% block autogrid_grid_column_header_filter %}
    <span>
        {% block autogrid_grid_column_header_filter_icon %}
            <a class="{{ isFilterActive ? linkClassActive : linkClass }}"
               role="button"
               onclick="var d=document.getElementById('filter{{ agId }}{{ field.name }}');d.style.display=d.style.display==='none'?'block':'none';event.stopPropagation();"
               aria-expanded="false"
            >{{ ag_icon(isFilterActive ? 'filter-active' : 'filter')|raw }}</a>
        {% endblock %}
        {% block autogrid_grid_column_header_filter_dropdown %}
            <div id="filter{{ agId }}{{ field.name }}"
                 class="z-10 bg-white rounded-lg shadow-lg absolute left-0 top-full mt-1 border border-gray-200 p-3 w-64 text-left"
                 style="display: none;"
                 onclick="event.stopPropagation();">
                {% set form = attribute(view.filterFormViews, field.name) %}
                {% if view.formThemes is not empty %}
                    {% form_theme form with view.formThemes %}
                {% endif %}
                {{ form_start(form) }}
                {% block autogrid_grid_column_header_filter_form_fields %}
                    {% if field.attributes.range_filter is defined %}
                        {% for searchField in attribute(form, field.name).children %}
                            {{ form_widget(searchField, {'attr': {'placeholder': field_label(searchField), 'class': 'w-full px-3 py-2 mb-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                            {{ loop.first ? '<div class="mb-2"></div>' }}
                        {% endfor %}
                    {% else %}
                        {{ form_widget(attribute(form, field.name), {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                    {% endif %}
                {% endblock %}
                {{ form_rest(form) }}
                {{ form_end(form) }}
                {% block autogrid_grid_column_header_filter_buttons %}
                    <div class="flex mt-3 space-x-2">
                        <button type="submit"
                                form="{{ form.vars.attr.id }}"
                                class="flex-1 text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-3 py-1.5 focus:outline-none"
                        >
                            {{- 'f0ska.autogrid.button.submit'|trans -}}
                        </button>
                        <a class="flex-1 text-center text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 focus:outline-none{% if not isFilterActive %} opacity-50 cursor-not-allowed{% endif %}"
                           href="{{ ag_run(agActionUrl, 'grid', {'filter': {(field.name): null}}) }}"
                        >
                            {{- 'f0ska.autogrid.button.reset'|trans -}}
                        </a>
                    </div>
                {% endblock %}
            </div>
        {% endblock %}
    </span>
{% endblock %}
